# 环境配置
APP_ENV=development

# 端口配置
WEB_PORT=5001

# 数据库配置
DB_HOST=localhost
DB_PORT=33065
DB_DATABASE=doopush
DB_USERNAME=root
DB_PASSWORD=password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=63795
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=doopush-secret-key-2024
JWT_ISSUER=doopush

# 审计日志配置
AUDIT_RETENTION_DAYS=365
AUDIT_AUTO_CLEANUP=true
AUDIT_CLEANUP_INTERVAL=24
AUDIT_CLEANUP_BATCH_SIZE=1000
